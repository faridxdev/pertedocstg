# ─────────────────────────────────────────────────────────────────────────────
# PerteDocsTG — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# NE JAMAIS committer le fichier .env dans Git
# ─────────────────────────────────────────────────────────────────────────────

# ── Django Core ──────────────────────────────────────────────────────────────
# Générez avec: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-very-long-secret-key-here-change-this-immediately

DEBUG=False

# Domaines autorisés (séparés par des virgules)
ALLOWED_HOSTS=pertedocs.tg,www.pertedocs.tg,localhost,127.0.0.1

# ── Base de données PostgreSQL ────────────────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=pertedocstg
DB_USER=pertedocstg_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_HOST=db
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_THIS_REDIS_PASSWORD@redis:6379/0
CACHE_URL=redis://:CHANGE_THIS_REDIS_PASSWORD@redis:6379/1

# ── Email SMTP ────────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre-email@gmail.com
EMAIL_HOST_PASSWORD=votre-app-password-gmail
DEFAULT_FROM_EMAIL=PerteDocsTG <noreply@pertedocs.tg>
SERVER_EMAIL=admin@pertedocs.tg

# ── SMS — Africa's Talking ────────────────────────────────────────────────────
SMS_PROVIDER=africas_talking
AFRICAS_TALKING_API_KEY=your_africas_talking_api_key
AFRICAS_TALKING_USERNAME=your_username
AFRICAS_TALKING_SENDER_ID=PerteDocsTG

# ── QR Code ───────────────────────────────────────────────────────────────────
QR_CODE_BASE_URL=https://pertedocs.tg/verification/

# ── Sécurité ──────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://pertedocs.tg,https://www.pertedocs.tg

# ── Stockage (optionnel — S3 compatible) ─────────────────────────────────────
# Décommenter pour utiliser un stockage externe (ex: MinIO, AWS S3)
# USE_S3=True
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_STORAGE_BUCKET_NAME=pertedocstg
# AWS_S3_ENDPOINT_URL=https://your-s3-endpoint.com
# AWS_S3_REGION_NAME=us-east-1

# ── Monitoring (optionnel) ────────────────────────────────────────────────────
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=PerteDocsTG
SUPPORT_EMAIL=support@pertedocs.tg
SUPPORT_PHONE=+228 22 XX XX XX
