# ─────────────────────────────────────────────────────────────────────────────
# PerteDocsTG — .env DÉVELOPPEMENT LOCAL (Windows / Mac / Linux)
# Copiez ce fichier en .env à la racine du projet
# ─────────────────────────────────────────────────────────────────────────────

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=dev-secret-key-changer-en-production-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Utiliser le settings de développement
DJANGO_SETTINGS_MODULE=config.settings_dev

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Installer PostgreSQL 16 : https://www.postgresql.org/download/windows/
DB_NAME=pertedocstg_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
# Option 1 : Redis via WSL2 (recommandé)
# Option 2 : Memurai (Redis natif Windows) : https://www.memurai.com/
# Option 3 : Upstash Redis (cloud gratuit) : https://upstash.com/
REDIS_URL=redis://127.0.0.1:6379/0

# ── Email (console en dev — pas besoin de config SMTP) ───────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=PerteDocsTG Dev <noreply@pertedocs.tg>

# ── SMS (laisser vide en dev — les SMS seront loggués) ───────────────────────
AFRICAS_TALKING_API_KEY=sandbox
AFRICAS_TALKING_USERNAME=sandbox
AFRICAS_TALKING_SENDER_ID=PerteDocsTG

# ── QR Code ───────────────────────────────────────────────────────────────────
QR_CODE_BASE_URL=http://localhost:8000/verification/

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
